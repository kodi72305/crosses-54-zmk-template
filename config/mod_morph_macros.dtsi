// Общие макросы для авто-шифтируемых символов (используются в crosses.keymap).
#ifndef MOD_MORPH_MACROS_DTSI
#define MOD_MORPH_MACROS_DTSI

#define ZB0 #binding-cells = <0>
// Модификаторы, которые отслеживает morph-поведение (оба Shift/Ctrl/Alt/GUI).
#define MODS_FOR_AS (MOD_LGUI|MOD_RGUI|MOD_LALT|MOD_RALT|MOD_LCTL|MOD_RCTL)

// Создаёт behavior as_<keycode>, который сам добавляет Shift, если любой мод зажат.
#define MOD_MORPH_AS(keycode)            \
    as_##keycode: as_##keycode {         \
        compatible = "zmk,behavior-mod-morph"; \
        ZB0;                             \
        bindings = <&as LS(keycode) keycode>, <&kp keycode>; \
        mods = <MODS_FOR_AS>;            \
        keep-mods = <MODS_FOR_AS>;       \
    };

// Упрощение для использования в keymap.
#define AS(keycode) &as_##keycode

#endif /* MOD_MORPH_MACROS_DTSI */
